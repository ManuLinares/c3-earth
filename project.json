{
  // Global options for all targets
  "dependency-search-paths":  [ "lib" ],
  "dependencies":  [ "raylib6" ],
  "sources":  [ "src/**" ],
  "build-dir": "build",
  "output": "build",

  // We can override specific target options
  "targets": {
    "default_whatever_name": { // the first one is what `c3c build` defaults to
      "type": "executable",
      "name": "c3_earth"
    },
    "web": {
      "type": "executable",
      "name": "index.html",
      "target": "emscripten",
      "link-args": [
        "--preload-file resources/img@resources/img",
        "-sASYNCIFY",
        "-sALLOW_MEMORY_GROWTH=1",
        "-sUSE_WEBGL2=1",
        "--shell-file resources/minshell.html"
      ]
    }
  }
}