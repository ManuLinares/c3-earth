{
  "dependency-search-paths":  [ "lib" ],
  "dependencies":  [ "raylib6" ],
  "sources":  [ "src/**" ],
  "build-dir": "build",
  "output": "build",
  "targets": {
    "c3_earth": {
      "type": "executable"
    },
    "web": {
      "name": "index.html",
      "target": "emscripten",
      "type": "executable",
      "opt": "Oz",
      "debug-info": "none",
      "link-args": [
        "-Oz",
        "--preload-file resources/img@resources/img",
        "-sASYNCIFY",
        "-sALLOW_MEMORY_GROWTH=1",
        "-sUSE_WEBGL2=1",
        "--shell-file resources/minshell.html"
      ]
    }
  },
  "cpu": "native",
  "opt": "Oz",
  "debug-info": "none",
  "link-args": ["-s"]
}