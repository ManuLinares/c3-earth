{
  "langrev": "1",
  "warnings":  [ "no-unused" ],
  "dependency-search-paths":  [ "lib" ],
  "dependencies":  [ "raylib6" ],
  "version": "0.1.0",
  "sources":  [ "src/**" ],
  "test-sources":  [ "test/**" ],
  "build-dir": "build",
  "output": "build",
  "targets": {
    "c3_earth": {
      "type": "executable"
    },
    "web": {
      "name": "index.html",
      "target": "emscripten",
      "type": "executable",
      "opt": "O3",
      "debug-info": "none",
      "link-args": [
        "-O3",
        "--preload-file resources/img@resources/img",
        "-sASYNCIFY",
        "-sALLOW_MEMORY_GROWTH=1",
        "-sUSE_WEBGL2=1",
        "--shell-file resources/minshell.html"
      ]
    }
  },
  "cpu": "generic",
  "opt": "O0",
  "debug-info": "full"
}